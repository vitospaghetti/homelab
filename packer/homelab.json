{
  "variables": {
    "proxmox_host": null,
    "proxmox_node": null,
    "proxmox_api_user": null,
    "proxmox_api_password": null,
    "storage_pool": null
  },
  
  "sensitive-variables": ["proxmox_api_password"],
  "builders": [
    {
      "type": "proxmox-iso",
      "proxmox_url": "https://{{ user `proxmox_host` }}/api2/json",
      "insecure_skip_tls_verify": true,
      "username": "{{ user `proxmox_api_user` }}",
      "password": "{{ user `proxmox_api_password` }}",

      "template_description": "Homelab template built on {{ isotime \"2006-01-02T15:04:05Z\" }}",
      "node": "{{user `proxmox_node`}}",
      "network_adapters": [
        {
          "model": "virtio",
          "bridge": "vmbr0",
          "firewall": true
        }
      ],
      "disks": [
        {
          "type": "scsi",
          "disk_size": "{{ user `disk_size` }}",
          "storage_pool": "{{ user `storage_pool` }}",
          "storage_pool_type": "lvm",
          "format": "raw",
          "io_thread": true
        }
      ],
      "scsi_controller": "virtio-scsi-single",

      "iso_file": "{{ user `storage_pool` }}:iso/debian-11.5.0-amd64-netinst.iso",
      "http_directory": "./",
      "boot_wait": "10s",
      "boot_command": [
        "<esc><wait>auto url=https://raw.githubusercontent.com/vitospaghetti/homelab/main/packer/bullseye.cfg<enter>"
      ],
      "unmount_iso": true,

      "cloud_init": true,
      "cloud_init_storage_pool": "{{ user `storage_pool` }}",
      "vm_id": "300",
      "vm_name": "homelab-template",
      "memory": "8192",
      "cpu_type": "qemu64",
      "sockets": "1",
      "cores": "4",
      "os": "l26",

      "ssh_username": "root",
      "ssh_password": "packer",
      "ssh_timeout": "60m"
    }
  ],
  "provisioners": [
    {
      "type": "file",
      "source": "cloud.cfg",
      "destination": "/etc/cloud/cloud.cfg"
    }
  ]
}
